            items: [
                { title: "Super Teaser Video PV", img: "https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?auto=format&fit=crop&w=600&q=80" },
                { title: "Special District Office Concept PV 1", img: "https://images.unsplash.com/photo-1509198397868-475647b2a1e5?auto=format&fit=crop&w=600&q=80" },
                { title: "Dream Rail Central Mainline Close-up", img: "https://images.unsplash.com/photo-1544620347-c4fd4a3d5957?auto=format&fit=crop&w=1200&q=80" },
                { title: "Quantum Shield Protocol Analysis", img: "https://images.unsplash.com/photo-1639322537228-f710d846310a?auto=format&fit=crop&w=1200&q=80" }
            ]
        };

        let sliderIndices = { info: 0, db: 0 };

        function navigateToPage(targetPageId) {
            const stageEl = document.getElementById('main-stage');
            if (targetPageId === 'home') {
                document.querySelectorAll('.fullview-overlay').forEach(el => {
                    el.classList.remove('active-page');
                    el.style.setProperty('pointer-events', 'none', 'important'); 
                });
                document.querySelectorAll('.nav-menu .nav-btn').forEach(b => b.classList.remove('active'));
                stageEl.classList.remove('stage-hidden'); 
                stageEl.style.setProperty('pointer-events', 'auto', 'important'); 
                document.getElementById('nav-home').classList.add('active');
                return;
            }

            let overlayEl = document.getElementById(`view-${targetPageId}-page`);
            let navBtnEl = document.getElementById(`nav-${targetPageId}`);

            if (overlayEl) {
                stageEl.classList.add('stage-hidden'); 
                stageEl.style.setProperty('pointer-events', 'none', 'important'); 

                document.querySelectorAll('.fullview-overlay').forEach(el => { 
                    if (el !== overlayEl) {
                        el.classList.remove('active-page');
                        el.style.setProperty('pointer-events', 'none', 'important'); 
                    }
                });
                document.querySelectorAll('.nav-menu .nav-btn').forEach(b => b.classList.remove('active'));

                overlayEl.classList.add('active-page');
                overlayEl.style.setProperty('pointer-events', 'auto', 'important'); 
                
                if (navBtnEl) navBtnEl.classList.add('active');
                overlayEl.scrollTop = 0;

                if (sliderIndices[targetPageId] !== undefined) {
                    renderSlider(targetPageId);
                }
                if (targetPageId === 'media') {
                    triggerMediaStaggerAnimation();
                }
            }
        }

        function initSliderDots(pageKey) {
            const dotsContainer = document.getElementById(`dots-${pageKey}`);
            if (!dotsContainer) return;
            dotsContainer.innerHTML = '';
            sliderData[pageKey].forEach((_, idx) => {
                const dot = document.createElement('div');
                dot.className = `indicator-dot ${idx === sliderIndices[pageKey] ? 'active' : ''}`;
                dot.onclick = () => { sliderIndices[pageKey] = idx; renderSlider(pageKey); };
                dotsContainer.appendChild(dot);
            });
        }

        function moveSlider(pageKey, direction) {
            const items = sliderData[pageKey];
            let currentIdx = sliderIndices[pageKey];
            currentIdx += direction;
            if (currentIdx < 0) currentIdx = items.length - 1;
            if (currentIdx >= items.length) currentIdx = 0;
            sliderIndices[pageKey] = currentIdx;
            renderSlider(pageKey);
        }

        function renderSlider(pageKey) {
            const items = sliderData[pageKey];
            const currentIdx = sliderIndices[pageKey];
            const pageOverlay = document.getElementById(`view-${pageKey}-page`);
            if (!pageOverlay) return;

            const cards = pageOverlay.querySelectorAll('.showcase-card');
            cards.forEach((card, idx) => {
                card.className = 'showcase-card';
                if (idx === currentIdx) card.classList.add('active');
                else if (idx === (currentIdx - 1 + items.length) % items.length) card.classList.add('prev');
                else if (idx === (currentIdx + 1) % items.length) card.classList.add('next');
            });

            const dots = pageOverlay.querySelectorAll('.indicator-dot');
            dots.forEach((dot, idx) => {
                if(idx === currentIdx) dot.classList.add('active');
                else dot.classList.remove('active');
            });

            const data = items[currentIdx];
            document.getElementById(`${pageKey}-render-title`).innerText = data.title;
            document.getElementById(`${pageKey}-render-quote`).innerText = data.quote;
            document.getElementById(`${pageKey}-render-body`).innerHTML = data.body;
        }

        function buildNotificationList() {
            const listContainer = document.getElementById('noti-list-container');
            if (!listContainer) return;
            listContainer.innerHTML = ''; 

            newsData.forEach((item, index) => {
                const card = document.createElement('div');
                card.className = `noti-item-card ${index === currentActiveNotiIdx ? 'item-active' : ''}`;
                card.onclick = () => switchNotiDetail(index, card);

                const dateEl = document.createElement('div');
                dateEl.className = 'noti-item-date';
                dateEl.innerText = item.date;

                const titleEl = document.createElement('div');
                titleEl.className = 'noti-item-title';
                titleEl.innerText = item.title;

                card.appendChild(dateEl);
                card.appendChild(titleEl);
                listContainer.appendChild(card);
            });
            refreshNotiDetailText();
        }

        function switchNotiDetail(index, element) {
            document.querySelectorAll('.noti-item-card').forEach(card => card.classList.remove('item-active'));
            if(element) element.classList.add('item-active');
            currentActiveNotiIdx = index;
            refreshNotiDetailText();
        }

        function refreshNotiDetailText() {
            const data = newsData[currentActiveNotiIdx];
            if (!data) return;
            document.getElementById('nd-title').innerText = data.title;
            document.getElementById('nd-meta').innerText = data.meta;
            document.getElementById('nd-content').innerHTML = data.content;
        }

        function buildMediaLayout() {
            const capsuleContainer = document.getElementById('media-capsules-wrap');
            const gridContainer = document.getElementById('media-matrix-grid');
            if (!capsuleContainer || !gridContainer) return;

            capsuleContainer.innerHTML = '';
            mediaConfig.tabs.forEach((tabName) => {
                const li = document.createElement('li');
                li.className = 'media-capsule-btn capsule-active';
                li.innerText = tabName;
                capsuleContainer.appendChild(li);
            });

            gridContainer.innerHTML = '';
            mediaConfig.items.forEach((item) => {
                const card = document.createElement('div');
                card.className = 'media-matrix-card';

                const coverWrap = document.createElement('div');
                coverWrap.className = 'matrix-video-cover-wrap';
                coverWrap.style.backgroundImage = `url('${item.img}')`;

                const playIndicator = document.createElement('div');
                playIndicator.className = 'matrix-play-indicator';
                
                const playIcon = document.createElement('div');
                playIcon.className = 'matrix-play-icon';
                playIcon.innerText = '▶';

                playIndicator.appendChild(playIcon);
                coverWrap.appendChild(playIndicator);

                const titleEl = document.createElement('div');
                titleEl.className = 'matrix-card-title';
                titleEl.innerText = item.title;

                card.appendChild(coverWrap);
                card.appendChild(titleEl);
                gridContainer.appendChild(card);
            });
        }

        function triggerMediaStaggerAnimation() {
            const cards = document.querySelectorAll('.media-matrix-card');
            cards.forEach((card, index) => {
                card.classList.remove('reveal-manifest');
                setTimeout(() => { card.classList.add('reveal-manifest'); }, index * 120); 
            });
        }

        // --- Quantum Space Stars Canvas ---
        const canvas = document.getElementById('star-canvas');
        const ctx = canvas.getContext('2d');
        let stars = [], meteors = [], trainX = -1000;
        const colors = ['rgba(0, 229, 255, ', 'rgba(180, 100, 255, ', 'rgba(255, 255, 255, '];

        class Meteor {
            constructor() { this.reset(); }
            reset() {
                this.x = Math.random() * canvas.width * 0.7; this.y = Math.random() * (canvas.height * 0.3);
                this.len = Math.random() * 100 + 60; this.speed = Math.random() * 6 + 3;
                this.color = colors[Math.floor(Math.random() * colors.length)];
            }
            update() { this.x += this.speed; this.y += this.speed * 0.4; if (this.x > canvas.width || this.y > canvas.height) this.reset(); }
            draw() {
                ctx.save(); ctx.beginPath();
                let gradient = ctx.createLinearGradient(this.x, this.y, this.x - this.len, this.y - this.len * 0.4);
                gradient.addColorStop(0, '#fff'); gradient.addColorStop(0.2, this.color + '0.4)'); gradient.addColorStop(1, 'transparent');
                ctx.strokeStyle = gradient; ctx.lineWidth = 1.2;
                ctx.moveTo(this.x, this.y); ctx.lineTo(this.x - this.len, this.y - this.len * 0.4);
                ctx.stroke(); ctx.restore();
            }
        }

        class Star {
            constructor() { this.reset(); }
            reset() {
                this.x = Math.random() * canvas.width; this.y = Math.random() * canvas.height;
                this.dist = Math.sqrt(Math.pow(this.x - canvas.width/2, 2) + Math.pow(this.y - canvas.height/2, 2));
                this.angle = Math.atan2(this.y - canvas.height/2, this.x - canvas.width/2);
                this.size = Math.random() * 1.2 + 0.4; this.speed = Math.random() * 0.0004 + 0.0001;
                this.color = colors[Math.floor(Math.random() * colors.length)] + (Math.random() * 0.3 + 0.2) + ')';
            }
            update() { this.angle += this.speed; }
            draw() {
                const x = canvas.width/2 + Math.cos(this.angle) * this.dist;
                const y = canvas.height/2 + Math.sin(this.angle) * this.dist;
                ctx.beginPath(); ctx.fillStyle = this.color; ctx.arc(x, y, this.size, 0, Math.PI*2); ctx.fill();
            }
        }

        function drawGhostTrain() {
            ctx.save(); ctx.globalAlpha = 0.45; ctx.strokeStyle = "rgba(0, 229, 255, 0.9)"; ctx.lineWidth = 2; ctx.shadowBlur = 10; ctx.shadowColor = "rgba(0, 229, 255, 0.8)";
            const trainY = canvas.height * 0.82; trainX += 1.2; if (trainX > canvas.width + 600) trainX = -800;
            for(let i=0; i<6; i++) { 
                let bx = trainX - (i * 125); ctx.strokeRect(bx, trainY, 115, 20);
                for(let j=0; j<4; j++) { ctx.strokeRect(bx + 8 + (j*26), trainY + 4, 18, 6); }
            }
            ctx.restore();
        }

        function initCanvas() {
            canvas.width = window.innerWidth; canvas.height = window.innerHeight;
            stars = []; meteors = [];
            for (let i = 0; i < 200; i++) stars.push(new Star());
            for (let i = 0; i < 4; i++) meteors.push(new Meteor());
        }

        function animate() {
            ctx.fillStyle = 'rgba(3, 5, 13, 0.06)'; ctx.fillRect(0, 0, canvas.width, canvas.height);
            drawGhostTrain(); stars.forEach(s => { s.update(); s.draw(); }); meteors.forEach(m => { m.update(); m.draw(); });
            requestAnimationFrame(animate);
        }

        window.addEventListener('resize', initCanvas);
        window.addEventListener('DOMContentLoaded', () => {
            buildNotificationList();
            buildMediaLayout();
            ['info', 'db'].forEach(key => { initSliderDots(key); renderSlider(key); });
            initCanvas(); animate();
        });
    </script>
</body>
</html>
