<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MX server | Future & Miracles</title>
    <style>
        :root {
            --accent: #00e5ff;
            --accent-glow: rgba(0, 229, 255, 0.4);
            --bg-dark: #03050d;
            --glass-border: rgba(255, 255, 255, 0.08);
        }

        * { 
            box-sizing: border-box; 
            -webkit-tap-highlight-color: transparent !important;
            outline: none !important;
        }
        
        body, html {
            margin: 0; padding: 0; width: 100%; height: 100%;
            background-color: var(--bg-dark) !important;
            overflow: hidden; 
            color: #fff; font-family: "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            user-select: none;
        }

        button, input, select, textarea, a, div {
            -webkit-tap-highlight-color: transparent !important;
            outline: none !important;
        }
        button:focus, div:focus, a:focus {
            outline: none !important;
            box-shadow: none !important;
        }

        /* --- Top Header Navigation --- */
        .top-header {
            position: fixed; top: 0; left: 0; width: 100%; height: 64px;
            display: flex; justify-content: space-between; align-items: center;
            padding: 0 4%; background: rgba(3, 5, 13, 0.9);
            backdrop-filter: blur(10px); border-bottom: 1px solid rgba(255,255,255,0.05);
            z-index: 3000;
        }
        .header-left { display: flex; align-items: center; gap: clamp(20px, 3vw, 40px); }
        .header-logo { font-size: clamp(0.95rem, 1.2vw, 1.1rem); letter-spacing: 4px; font-weight: 600; color: #fff; white-space: nowrap; }
        
        .nav-menu { display: flex; gap: clamp(15px, 2.5vw, 35px); }
        .nav-btn {
            font-size: clamp(0.8rem, 1vw, 0.9rem); color: rgba(255,255,255,0.7); cursor: pointer;
            transition: 0.3s; position: relative; letter-spacing: 1px; white-space: nowrap;
        }
        .nav-btn.active, .nav-btn:hover { color: #fff; }
        .nav-btn.active::before {
            content: '+'; position: absolute; left: -12px; color: var(--accent); font-weight: bold;
        }

        .header-right { display: flex; gap: 24px; color: rgba(255,255,255,0.6); font-size: 0.95rem; align-items: center; }
        .icon-btn { cursor: pointer; transition: 0.3s; display: flex; align-items: center; gap: 4px; position: relative; }
        .icon-btn:hover { color: #fff; }
        .lang-text { font-size: 0.75rem; letter-spacing: 1px; font-weight: bold; border: 1px solid rgba(255,255,255,0.3); padding: 2px 6px; border-radius: 3px; }

        /* --- Main Stage (Home View) --- */
        #main-stage { 
            position: relative; width: 100%; height: 100%; z-index: 10; 
            background-color: var(--bg-dark); 
            opacity: 1; transition: opacity 0.3s ease-in-out;
            pointer-events: auto; 
        }
        #main-stage.stage-hidden { opacity: 0; pointer-events: none !important; }
        #star-canvas { position: absolute; inset: 0; z-index: 1; pointer-events: none; }
        .character-split-layer {
            position: absolute; inset: 0; z-index: 2;
            background: linear-gradient(135deg, rgba(15, 23, 42, 0.75) 0%, rgba(30, 41, 59, 0.5) 50%, transparent 50.01%);
            backdrop-filter: blur(2px); pointer-events: none;
        }

        .view-homepage-content { width: 100%; height: 100%; position: absolute; inset: 0; display: flex; justify-content: center; align-items: center; }
        .center-hero { text-align: center; z-index: 5; pointer-events: none; }
        .title-large { font-size: clamp(2.5rem, 5vw, 4.5rem); letter-spacing: 12px; font-weight: 300; margin: 0; text-shadow: 0 0 40px rgba(0,0,0,0.8); }
        .title-sub { font-size: clamp(0.9rem, 1.5vw, 1.2rem); letter-spacing: 8px; color: rgba(255,255,255,0.6); margin: 15px 0 0 0; }
        .quote-text { margin-top: 5vh; font-size: clamp(0.75rem, 0.9vw, 0.85rem); color: rgba(255,255,255,0.4); letter-spacing: 3px; line-height: 1.8; max-width: 600px; }

        /* --- Fullview Overlay View --- */
        .fullview-overlay {
            position: fixed; inset: 0; width: 100%; height: 100%; z-index: 1500; 
            padding: 90px 6% 40px 6%;
            background: rgba(3, 5, 13, 0.98); backdrop-filter: blur(30px);
            display: flex; flex-direction: column; 
            opacity: 0; 
            pointer-events: none !important; 
            transition: opacity 0.3s ease-in-out;
            overflow-y: auto; 
        }
        .fullview-overlay.active-page { opacity: 1; pointer-events: auto !important; }

        .fullview-overlay::-webkit-scrollbar, 
        .noti-sidebar-list::-webkit-scrollbar, 
        .generic-detail-panel::-webkit-scrollbar,
        .media-grid-container::-webkit-scrollbar { width: 4px; }
        .fullview-overlay::-webkit-scrollbar-thumb, 
        .noti-sidebar-list::-webkit-scrollbar-thumb, 
        .generic-detail-panel::-webkit-scrollbar-thumb,
        .media-grid-container::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.12); border-radius: 2px; }
        
        .page-header-area { display: flex; justify-content: space-between; align-items: flex-end; border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 15px; margin-bottom: 25px; flex-shrink: 0; }
        .page-main-title { font-size: clamp(1.4rem, 2.2vw, 2.2rem); font-weight: 300; margin: 0; letter-spacing: 3px; }
        .page-sub-title { font-size: 0.75rem; color: var(--accent); letter-spacing: 2px; margin-top: 5px; font-family: monospace; }
        .page-back-btn {
            display: flex; align-items: center; gap: 8px; font-size: 0.85rem; color: rgba(255,255,255,0.6);
            cursor: pointer; transition: 0.3s; border: 1px solid rgba(255,255,255,0.15); padding: 6px 16px; border-radius: 20px;
        }
        .page-back-btn:hover { color: #fff; border-color: var(--accent); box-shadow: 0 0 15px rgba(0,229,255,0.15); }

        /* ================= Carousel Sliders ================= */
        .slider-showcase-container { display: flex; align-items: center; justify-content: center; width: 100%; gap: 30px; position: relative; margin-top: 10px; flex-shrink: 0; }
        .cards-viewport { display: flex; align-items: center; justify-content: center; width: 85%; height: clamp(240px, 32vh, 380px); position: relative; overflow: hidden; }
        .showcase-card {
            position: absolute; width: 55%; height: 100%; background-size: cover; background-position: center; border: 1px solid rgba(255,255,255,0.1);
            clip-path: polygon(0 0, calc(100% - 40px) 0, 100% 40px, 100% 100%, 40px 100%, 0 calc(100% - 40px)); transition: all 0.5s cubic-bezier(0.25, 1, 0.5, 1); opacity: 0; pointer-events: none; z-index: 1;
        }
        .showcase-card.active { opacity: 1; pointer-events: auto; transform: scale(1) translateX(0); z-index: 3; border-color: var(--accent); }
        .showcase-card.prev { opacity: 0.25; transform: scale(0.85) translateX(-70%); z-index: 2; }
        .showcase-card.next { opacity: 0.25; transform: scale(0.85) translateX(70%); z-index: 2; }
        .slide-arrow { font-size: 2rem; color: rgba(255,255,255,0.3); cursor: pointer; transition: 0.3s; padding: 10px; z-index: 10; user-select: none; }
        .slide-arrow:hover { color: #fff; text-shadow: 0 0 10px var(--accent); }
        .indicator-dots { display: flex; justify-content: center; gap: 12px; margin: 20px 0; align-items: center; flex-shrink: 0; }
        .indicator-dot { width: 6px; height: 6px; background: rgba(255,255,255,0.25); border-radius: 50%; transition: 0.3s; cursor: pointer; }
        .indicator-dot.active { background: #fff; transform: scale(1.3); box-shadow: 0 0 10px #fff, 0 0 4px var(--accent); }

        .content-display-panel { width: 100%; max-width: 900px; margin: 10px auto 0 auto; text-align: left; }
        .dynamic-title-group { margin-bottom: 16px; }
        .dynamic-main-title { font-size: 1.7rem; font-weight: 500; margin: 0 0 8px 0; color: #fff; letter-spacing: 1px; }
        .dynamic-sub-quote { font-size: 0.95rem; color: var(--accent); font-weight: bold; letter-spacing: 1px; margin-bottom: 20px; display: block; }
        .dynamic-body-text { font-size: 0.95rem; color: rgba(255,255,255,0.7); line-height: 1.9; text-align: justify; padding-bottom: 60px; }

        /* ================= Bulletin Split View ================= */
        .page-layout-container { display: flex; gap: 30px; flex-grow: 1; height: calc(100vh - 220px); min-height: 400px; overflow: hidden; }
        .noti-sidebar-list { width: 32%; display: flex; flex-direction: column; gap: 10px; overflow-y: auto; padding-right: 6px; height: 100%; padding-bottom: 40px; }
        .noti-item-card { background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04); padding: 15px; border-radius: 6px; cursor: pointer; transition: 0.25s; flex-shrink: 0; }
        .noti-item-card:hover { background: rgba(255,255,255,0.05); border-color: rgba(0, 229, 255, 0.4); }
        .noti-item-card.item-active { background: rgba(0, 229, 255, 0.05); border-color: var(--accent); box-shadow: inset 0 0 15px rgba(0, 229, 255, 0.05); }
        .noti-item-date { font-size: 0.75rem; color: rgba(255,255,255,0.35); font-family: monospace; letter-spacing: 0.5px; }
        .noti-item-title { font-size: 0.88rem; margin: 6px 0 0 0; font-weight: 400; color: rgba(255,255,255,0.7); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .noti-item-card.item-active .noti-item-title { color: #fff; font-weight: 500; }
        
        .generic-detail-panel { width: 68%; background: rgba(255,255,255,0.01); border: 1px solid rgba(255,255,255,0.03); border-radius: 8px; padding: 35px; overflow-y: auto; height: 100%; padding-bottom: 40px; }
        .detail-title { font-size: 1.4rem; font-weight: 400; margin: 0 0 10px 0; color: #fff; letter-spacing: 0.5px; line-height: 1.4; }
        .detail-meta { font-size: 0.8rem; color: rgba(255,255,255,0.4); font-family: monospace; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 14px; margin-bottom: 22px; }
        .detail-content { line-height: 1.85; color: rgba(255,255,255,0.75); font-size: 0.92rem; text-align: justify; }
        .detail-content p { margin: 0 0 16px 0; }

        /* ================= Media Sci-Fi Light Override ================= */
        .media-page-override {
            background: radial-gradient(circle at 50% 30%, rgba(245, 247, 250, 0.96) 0%, rgba(230, 235, 243, 0.98) 100%) !important;
            background-image: url('https://pub-c5e31b5cdafb419a82e69d040106134a.r2.dev/mock-map-bg.svg'), 
                              radial-gradient(circle at 50% 30%, rgba(245, 247, 250, 0.95) 0%, rgba(232, 237, 245, 0.98) 100%) !important;
            background-size: cover !important; background-position: center !important; color: #1e293b !important;
        }
        .media-page-override .page-main-title { color: #0f172a; font-weight: 600; }
        .media-page-override .page-back-btn { color: #475569; border-color: rgba(15,23,42,0.15); }
        .media-page-override .page-back-btn:hover { color: #0f172a; border-color: #0f172a; box-shadow: 0 0 15px rgba(0,0,0,0.05); }

        .media-capsule-container { display: flex; gap: 14px; margin: 5px 0 25px 0; flex-shrink: 0; list-style: none; padding: 0; }
        .media-capsule-btn {
            padding: 8px 24px; font-size: 0.88rem; font-weight: 500; color: #475569;
            background: #fff; border: 1px solid rgba(15,23,42,0.08); border-radius: 30px;
            cursor: pointer; transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
            letter-spacing: 2px; position: relative; box-shadow: 0 2px 6px rgba(0,0,0,0.02);
        }
        .media-capsule-btn.capsule-active {
            background: #11131a; color: #fff; border-color: #11131a; font-weight: 600;
            box-shadow: 0 4px 12px rgba(17,19,26,0.15);
        }
        .media-capsule-btn.capsule-active::before, .media-capsule-btn.capsule-active::after {
            content: '+'; position: absolute; font-size: 0.65rem; color: rgba(255,255,255,0.4); font-family: sans-serif; top: 50%; transform: translateY(-50%);
        }
        .media-capsule-btn.capsule-active::before { left: 8px; }
        .media-capsule-btn.capsule-active::after { right: 8px; }

        .media-grid-container { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 25px; overflow-y: auto; flex-grow: 1; padding-bottom: 40px; width: 100%; }
        .media-matrix-card {
            background: #fff; border: 1px solid rgba(15,23,42,0.06); padding: 5px; border-radius: 4px; box-shadow: 0 4px 14px rgba(15,23,42,0.03);
            clip-path: polygon(0 0, calc(100% - 24px) 0, 100% 24px, 100% 100%, 24px 100%, 0 calc(100% - 24px)); cursor: pointer; position: relative; width: 100%; opacity: 0; transform: translateX(-20px) scale(0.96);
        }
        .media-matrix-card.reveal-manifest { opacity: 1; transform: translateX(0) scale(1); transition: opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1), transform 0.6s cubic-bezier(0.22, 1, 0.36, 1); }
        .media-matrix-card:hover { border-color: #11131a; box-shadow: 0 6px 20px rgba(17,19,26,0.1); }

        .matrix-video-cover-wrap { width: 100%; aspect-ratio: 16 / 9; background-size: cover; background-position: center; position: relative; overflow: hidden; clip-path: polygon(0 0, calc(100% - 22px) 0, 100% 22px, 100% 100%, 22px 100%, 0 calc(100% - 22px)); }
        .matrix-play-indicator { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.15); transition: 0.3s; }
        .matrix-play-icon {
            width: 44px; height: 44px; background: rgba(255,255,255,0.9); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #11131a;
            font-size: 1.1rem; padding-left: 3px; box-shadow: 0 4px 10px rgba(0,0,0,0.15); transition: 0.25s;
        }
        .media-matrix-card:hover .matrix-play-icon { transform: scale(1.1); background: #11131a; color: #fff; }
        .matrix-card-title { font-size: 0.85rem; font-weight: 600; color: #1e293b; margin: 12px 6px 8px 6px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; letter-spacing: 0.5px; }
    </style>
</head>
